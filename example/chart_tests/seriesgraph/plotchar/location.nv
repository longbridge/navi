// 正确结果：每 20 根柱出现一次，5 种位置同时显示：
// "A"=AboveBar（柱上）、"B"=BelowBar（柱下）、
// "T"=Top（面板顶部）、"D"=Bottom（面板底部）、"●"=Absolute（跟随 close 价格）
indicator("Chart Test: plotchar/location", overlay: true);

let t = bar_index % 20 == 0;
plot_char(t, "AboveBar", char: "A", location: Location.AboveBar,  color: Color.BLUE);
plot_char(t, "BelowBar", char: "B", location: Location.BelowBar,  color: Color.RED);
plot_char(t, "Top",      char: "T", location: Location.Top,       color: Color.GREEN);
plot_char(t, "Bottom",   char: "D", location: Location.Bottom,    color: Color.PURPLE);
plot_char(close, "Absolute", char: "●", location: Location.Absolute, color: Color.ORANGE);
